# Copy to .env and fill in the values, then run ./deploy.sh

# ── VPN ────────────────────────────────────────────────────────────────────
# Supported providers: protonvpn | mullvad
VPN_PROVIDER=protonvpn

# WireGuard private key from your VPN provider.
# ProtonVPN: account.proton.me/vpn/wireguard → create/download a config
#            → open the .conf file → copy the PrivateKey value
# Mullvad:   mullvad.net/account/wireguard-config → copy PrivateKey
VPN_PRIVATE_KEY=your_private_key_here

# Mullvad only — your internal WireGuard address (e.g. 10.64.x.x/32).
# Leave blank for ProtonVPN.
VPN_ADDRESSES=

# Country for server selection (gluetun picks the best server in that country).
VPN_COUNTRY=United States

# ── Desktop ─────────────────────────────────────────────────────────────────
# Desktop environment: xfce | mate | kde
DESKTOP_ENV=xfce

# Password for the web desktop session (https://<host>:4001)
DESKTOP_PASSWORD=changeme_to_something_strong

# ── System ──────────────────────────────────────────────────────────────────
TZ=America/New_York
